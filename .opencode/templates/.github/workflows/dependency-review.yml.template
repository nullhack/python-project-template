name: 'Dependency Review'
on: [pull_request]

permissions:
  contents: read

jobs:
  dependency-review:
    runs-on: ubuntu-latest
    steps:
      - name: 'Checkout Repository'
        uses: actions/checkout@v4
        
      - name: 'Dependency Review'
        uses: actions/dependency-review-action@v4
        with:
          # Fail if any vulnerabilities are found
          fail-on-severity: moderate
          # Allow certain licenses (common permissive licenses)
          allow-licenses: GPL-2.0, GPL-3.0, LGPL-2.1, LGPL-3.0, MIT, BSD-2-Clause, BSD-3-Clause, ISC, Apache-2.0, Unlicense, 0BSD
          # Deny problematic licenses
          deny-licenses: AGPL-1.0, AGPL-3.0, GPL-1.0
          # Comment on PR with results
          comment-summary-in-pr: always